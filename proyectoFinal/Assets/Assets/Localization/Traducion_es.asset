%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Traducion_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: a6dfaab2f9b3a344faa9d8eef5433298, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 35434348544
    m_Localized: Empezar
    m_Metadata:
      m_Items: []
  - m_Id: 103411433472
    m_Localized: Opciones
    m_Metadata:
      m_Items: []
  - m_Id: 145530634240
    m_Localized: "Ingl\xE9s"
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721923
    m_Localized: "???: Que rico est\xE1 este t\xE9 matcha"
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721921
    m_Localized: "Pyotr: Disculpa, \xBFte puedo hacer una pregunta?"
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721920
    m_Localized: "Pyotr: Hola ni\xF1a"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850164
    m_Localized: '???: No hay de que.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850163
    m_Localized: 'Pyotr: Gracias por la ayuda.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850162
    m_Localized: '???: Si sigues por esta calle para arriba, puede que encuentres
      algo, al lado de la taberna.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850161
    m_Localized: 'Pyotr: Busco algunos tablones de madera.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850160
    m_Localized: "???: Eso es bondadoso de tu parte. \xBFY qu\xE9 est\xE1s buscando?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850159
    m_Localized: 'Pyotr: Lo hago sin que lo sepa.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850158
    m_Localized: '???: Conozco a Lilia, he oido que es una genio. Aunque por lo que
      he oido se me hace raro que quiera ayuda de alguien.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850157
    m_Localized: 'Pyotr: Se llama Lilia, estoy en su taller y le estoy ayudando a
      encontrar unos materiales.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850156
    m_Localized: "???: \xBFY qui\xE9n es esa amiga?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850155
    m_Localized: "Pyotr: Lo siento si te he ofendido no era mi intenci\xF3n. Solo
      quiero ayudar a una amiga."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850154
    m_Localized: '???: No me trate de usted, que aun soy joven.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850153
    m_Localized: 'Pyotr: Mire, soy una persona mayor, estoy cansado y no estoy para
      pelearme con alguien.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850152
    m_Localized: "???: \xBFQue ha pasado?\xBFSe te ha comido la lengua el gato?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850151
    m_Localized: "Se r\xEDe, burlandose."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850150
    m_Localized: 'Pyotr: Vale, vale, ya me voy.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850149
    m_Localized: "???: \xA1QUE TE VAYAS! O aviso a los guardias."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850148
    m_Localized: 'Pyotr: Pero necesito tu ayuda para encontrar algo.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850147
    m_Localized: '???: Mira, vete. No quiero verte.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850146
    m_Localized: 'Pyotr: Te estas empezando a pasar ya.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850145
    m_Localized: Ahora Pyotr tambien esta empezando a molestarse.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850144
    m_Localized: "???: Si hace falta, no va a venir un viejo como tu a llamarme ni\xF1a."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850143
    m_Localized: 'Pyotr: Ya te he dicho que lo siento, no hace falta seguir con esto.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850142
    m_Localized: "???: \xA1No me estoy pasando, estoy cansada de que me confundan
      con una ni\xF1a!"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850141
    m_Localized: Alza la voz, medio gritando.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850140
    m_Localized: "???: No pasa nada, que tengas buen d\xEDa se\xF1or."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850139
    m_Localized: 'Pyotr: Perfecto, muchas gracias. Y disculpa por lo del principio.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850138
    m_Localized: '???: Si sigues por esta calle para arriba, puede que encuentres
      algo, al lado de la taberna'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850137
    m_Localized: Se rasca la barbilla mientras piensa.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850136
    m_Localized: 'Pyotr: Busco algunos tablones de madera'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850135
    m_Localized: "???: Por supuesto, \xBFque buscas?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850134
    m_Localized: "Pyotr: Ahora que hemos solucionado este primer contacto, \xBFme
      podr\xEDas ayudar a encontrar una cosa?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850133
    m_Localized: "???: La verdad que si que eres bajito, no me hab\xEDa fijado"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850132
    m_Localized: Pyotr:Lo entiendo, me pasaba lo mismo a tu edad. Yo siempre he sido
      bajito y entiendo tu enfado
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850131
    m_Localized: "???: Es que me sienta muy mal cuando me tratan de ni\xF1a. Lo siento
      si he sido un poco intensa."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850130
    m_Localized: "Pyotr: Muchas gracias se\xF1orita."
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850129
    m_Localized: "???: Al final de la calle lo podr\xE1s encontrar"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850128
    m_Localized: "Pyotr: Perfecto. \xBFY por donde se va a la taberna?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850127
    m_Localized: '???: Mmmm. Creo que por la taberna hay algo tirado en el suelo.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850126
    m_Localized: "Pyotr: \xBFSabes por donde puedo encontrar unos tablones de madera?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850125
    m_Localized: '???: Bueno dime alguna a ver si te puedo ayudar'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850124
    m_Localized: 'Pyotr: Varias cosas la verdad.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850123
    m_Localized: "???: \xBFQu\xE9 es lo que estas buscando concretamene?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850122
    m_Localized: "Pyotr: Estoy buscando unas cosas para una amiga, \xBFme podr\xEDas
      ayudar?"
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850121
    m_Localized: '???: Si claro dime'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850120
    m_Localized: Mejor no decir nada...
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850119
    m_Localized: 'Pyotr: Creo que ya te estas pasando'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850118
    m_Localized: 'Pyotr: Lo he entendido. Lo siento de verdad.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850117
    m_Localized: '???: Es como si yo te digo, oye momia'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850116
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850115
    m_Localized: '???: Se que mi estatura no ayuda, pero no por eso me tienes que
      hacer prejuicios.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850114
    m_Localized: 'Pyotr: Ah... lo siento mucho'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850113
    m_Localized: Pyotr pone la mano en la nuca.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850112
    m_Localized: Se nota enfadada.
    m_Metadata:
      m_Items: []
  - m_Id: 10173553655808
    m_Localized: "???: \xBFA qui\xE9n llamas ni\xF1a? Tengo 32 a\xF1os"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931796
    m_Localized: "Pyotr: Muchas gracias, amigo, cu\xEDdate."
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931795
    m_Localized: "???: Mira Pyotr, si giras a la izquierda y vas al final hay como
      un vertedero algo encontrar\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931794
    m_Localized: '???: Cierto...'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931793
    m_Localized: "Pyotr: La putada es que entre que no tengo dinero y no soy de aqu\xED
      no voy a poder comprarla."
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931792
    m_Localized: "???: Por aqu\xED cerca hay una tienda donde puedes comprarlos."
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931791
    m_Localized: 'Pyotr: Estoy buscando unos engranajes.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931790
    m_Localized: 'Pyotr: Pues ahora que lo dices si.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931789
    m_Localized: "???: \xBFDeseas algo?"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931788
    m_Localized: 'Pyotr: Tranquilo lo entiendo.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931787
    m_Localized: '???: Lo siento no se la dejo a nadie.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931786
    m_Localized: "Pyotr: Pues es muy bonita, \xBFla puedo ver?"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931785
    m_Localized: '???: Gracias, es una herencia familiar.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931784
    m_Localized: 'Pyotr: Yo soy Pyotr'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931783
    m_Localized: 'Pyotr: Y a ti que te importa quien soy'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931782
    m_Localized: "???: Adem\xE1s, \xBFqui\xE9n eres t\xFA?"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931781
    m_Localized: "???: \xBFA ti que te importa?"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931780
    m_Localized: 'Pyotr: Simplemente pregunto si es legal esa arma.'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931779
    m_Localized: "???: \xBFPerdona?"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931778
    m_Localized: "???: Hace buen d\xEDa"
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931777
    m_Localized: 'Pyotr: Bonita espada amigo'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931776
    m_Localized: "Pyotr: Disculpa pero, \xBFacaso se pueden llevar armas en esta
      ciudad?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463013
    m_Localized: 'Pyotr: De acuerdo gracias.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463012
    m_Localized: '???: Si, bajando la calle, cerca de la muralla creo que hay restos
      donde puede haber'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463011
    m_Localized: '???: No hay de que, y recuerda, ten fe.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463010
    m_Localized: 'Pyotr: De acuerdo gracias.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463009
    m_Localized: '???: Si, bajando la calle, cerca de la muralla creo que hay restos
      donde puede haber'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463008
    m_Localized: "Pyotr: Pues estoy buscando unos muelles, \xBFsabes donde encontrar?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463007
    m_Localized: "???: \xBFNecesitas algo m\xE1s?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463006
    m_Localized: '???: No hay de que'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463005
    m_Localized: 'Pyotr: Sigo teniendo mis dudas... pero gracias por la charla'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463004
    m_Localized: 'Pyotr: Eso espero...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463003
    m_Localized: '???: Los dioses son misericordiosos, seguro que tiene un plan para
      ella.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463002
    m_Localized: "???: Entiendo tu frustaci\xF3n amigo, pero no por eso tienes que
      perder la fe."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463001
    m_Localized: "Pyotr: Es una persona buena y nunca le ha hecho da\xF1o a nadie,
      porque le tiene que pasar esto a ella"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463000
    m_Localized: "Pyotr: Mi mujer est\xE1 enferma y no va a mejor."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462999
    m_Localized: "???: \xBFPuedo saber porqu\xE9?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462998
    m_Localized: '???: Eso le puede pasar a todas las personas.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462997
    m_Localized: "Pyotr: Necesito saber donde puedo encontrar muelles \xBFSabes donde
      encontrar?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462996
    m_Localized: 'Pyotr: (con los ojos llorosos) Ultimamente estoy dejando de tener
      fe en los dioses'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462995
    m_Localized: 'Pyotr: La verdad que...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462994
    m_Localized: "???: \xBFNecesitas algo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462993
    m_Localized: 'Pyotr: Ah vale...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462992
    m_Localized: Pyotr agacha la cabeza.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462991
    m_Localized: '???: La verdad que no, pero soy bastante creyente.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462990
    m_Localized: "???: \xBFSabes? Adios, no tengo tiempo para tonter\xEDas."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462989
    m_Localized: 'Pyotr: Seria muy feo si un cura me llamase viejo chocho'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462988
    m_Localized: 'Pyotr: Eh, tampoco hace falta que faltes el respeto a la tercera
      edad'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462987
    m_Localized: '???: Solo eres un viejo chocho'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462986
    m_Localized: '???: Lo que hay que aguantar.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462985
    m_Localized: Se rasca las orejas.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462984
    m_Localized: 'Pyotr: Si eres un vampiro o no'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462983
    m_Localized: "???: \xBFSaber que?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462982
    m_Localized: "Pyotr: Perooo... \xBFlo sabes no?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462981
    m_Localized: "Pyotr: En realidad te pregunt\xE9 si eres cura o vampiro."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462980
    m_Localized: Pyotr levanta los hombros.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462979
    m_Localized: '???: Me acabas de preguntar si soy un vampiro.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462978
    m_Localized: "???: \xBFC\xF3mo no quieres que me ofenda?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462977
    m_Localized: 'Pyotr: Solo es una duda no te ofendas hombre.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462976
    m_Localized: "???: \xBFNadie te ense\xF1\xF3 modales?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268715
    m_Localized: Frunce las cejas.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268714
    m_Localized: '???: Que Dios se apieda de nosotros'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268713
    m_Localized: "Pyotr: Perdona, \xBFeres cura?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268712
    m_Localized: "Pyotr: Disculpa, \xBFeres un cura o un vampiro?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268711
    m_Localized: "Pyotr: Muchas gracias, amigo, cu\xEDdate."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268710
    m_Localized: "???: Cierto... Mira Pyotr, si giras a la izquierda y vas al final
      hay como un vertedero algo encontrar\xE1s"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268709
    m_Localized: "Pyotr: La putada es que entre que no tengo dinero y no soy de aqu\xED
      no voy a poder comprarla."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268708
    m_Localized: "???: Por aqu\xED cerca hay una tienda donde puedes comprarlos"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268707
    m_Localized: 'Pyotr: Estoy buscando unos engranajes'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268706
    m_Localized: "???:: Dime Pyotr, \xBFqu\xE9 necesitas?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268705
    m_Localized: 'Pyotr: Gracias amigo'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268704
    m_Localized: "Pyotr sonr\xEDe y le da la mano."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268703
    m_Localized: '???: De acuerdo, tienes mi confianza.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268702
    m_Localized: Le ofrece la mano a Pyotr.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268701
    m_Localized: 'Pyotr: Vale, tranquilo'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268700
    m_Localized: '???: Vete.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268699
    m_Localized: Desenfunde completamente su espada.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268698
    m_Localized: 'Pyotr: Por favor necesito ayuda'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268697
    m_Localized: '???: Mejor desaparece de mi vista.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268696
    m_Localized: Antes de poder terminar, le interrumpe.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268695
    m_Localized: 'Pyotr: Yo no quiero problemas amigo solo...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268694
    m_Localized: '???: Si quieres que estemos bien respondeme.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268693
    m_Localized: Desenfunde media espada.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268692
    m_Localized: 'Pyotr: Estoy ayudando a una amiga buscando unos elementos y necesito
      ayuda'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268691
    m_Localized: "Pyotr: \xBFEstas haciendo muchas preguntas no?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268690
    m_Localized: "???: \xBFY que haces por aqu\xED?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268689
    m_Localized: 'Pyotr: La verdad que no, soy de la planta de abajo'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268688
    m_Localized: "???: \xBFNo eres de por aqu\xED verdad?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268687
    m_Localized: "Pyotr: Mejor me voy est\xE1s muy mal de la cabeza"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268686
    m_Localized: "???: Respondeme o te parto en dos como un palo de bamb\xFA."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268685
    m_Localized: "???: Pero a\xFAn as\xED no me has respondido."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268684
    m_Localized: Desenfunde la espada.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268683
    m_Localized: "???: Bueno, viendolo as\xED tienes raz\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268682
    m_Localized: Parece que eso lo calma, enfundando su espada.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268681
    m_Localized: 'Pyotr: Solo digo que es raro que no seas guardia y tengas una espada
      contigo.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268680
    m_Localized: 'Pyotr: No, no yo no oculto nada.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268679
    m_Localized: Pyotr mira brevemente a la espada, aclarandose la garganta.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268678
    m_Localized: "M\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268677
    m_Localized: "???: \xBFOcultas algo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268676
    m_Localized: "Con cada palabra que dice, desenfunde m\xE1s su espada."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268675
    m_Localized: "???: Porque tendr\xEDa que parecer un guardia."
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268674
    m_Localized: 'Pyotr: Solo digo que no pareces un guardia ni nada.'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268673
    m_Localized: Lentamente, empieza a desenfundar su espada.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268672
    m_Localized: '???: Si quieres que estemos bien respondeme.'
    m_Metadata:
      m_Items: []
  - m_Id: 3292595779092480
    m_Localized: Salir
    m_Metadata:
      m_Items: []
  - m_Id: 3292750330806272
    m_Localized: Guardar
    m_Metadata:
      m_Items: []
  - m_Id: 3293267467517952
    m_Localized: "Espa\xF1ol"
    m_Metadata:
      m_Items: []
  - m_Id: 3609736646574080
    m_Localized: Opciones
    m_Metadata:
      m_Items: []
  - m_Id: 3609796801282048
    m_Localized: Volver
    m_Metadata:
      m_Items: []
  - m_Id: 3613258045800448
    m_Localized: Cargar
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904624
    m_Localized: Mejor volver con Lilia y darle los materiales.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904623
    m_Localized: "Pyotr: Que hombre m\xE1s raro"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904622
    m_Localized: "Extra\xF1o: Nos volveremos a ver, adios"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904621
    m_Localized: "Quizas deber\xEDa volver con Lilia, se est\xE1 haciendo tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904620
    m_Localized: 'Pyotr: Ah.. muchisimas gracias jefe'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904619
    m_Localized: "El extra\xF1o da a Pyotr una roca morada de un tono extra\xF1o."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904618
    m_Localized: "Extra\xF1o: Has pasado la prueba, toma este objeto como recompensa."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904617
    m_Localized: "Pyotr: \xBFPero si los cultivos est\xE1n en mi planta?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904616
    m_Localized: 'Pyotr: A mi realmente me emociona'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904615
    m_Localized: "Extra\xF1o: Estar aqu\xED viendo este campo de alcachofas..."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904614
    m_Localized: "Pyotr: \xBFHay un r\xEDo aqu\xED arriba?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904613
    m_Localized: "Pyotr: El r\xEDo... una mierda"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904612
    m_Localized: "Extra\xF1o: \xBFQu\xE9 opinas del r\xEDo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904611
    m_Localized: "Pyotr: \xBFQui\xE9n es tu cu\xF1ado?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904610
    m_Localized: "Pyotr: Ven aqu\xED orej\xF3n"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904609
    m_Localized: "Extra\xF1o: \xBFQu\xE9 le dije a mi cu\xF1ado?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904608
    m_Localized: 'Pyotr: Pero no son ni las 18:00'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904607
    m_Localized: "Pyotr: \xBFPor qu\xE9?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904606
    m_Localized: "Extra\xF1o: \xA1YA ES TARDE!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904605
    m_Localized: 'Pyotr: Menudo personaje...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904604
    m_Localized: "Extra\xF1o: No existo, no soy persona"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904603
    m_Localized: 'Pyotr: Solo has cerrado los ojos.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904602
    m_Localized: "Pyotr se lo mira, estra\xF1ado."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904601
    m_Localized: "El Extra\xF1o cierra los ojos sin moverse del sitio."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904600
    m_Localized: "Extra\xF1o: Me tengo que ir"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904599
    m_Localized: "Pyotr: \xBFC\xF3mo? \xBFPor qu\xE9 no?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904598
    m_Localized: "Extra\xF1o: Lo siento pero yo no doy ese tipo de informaci\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904597
    m_Localized: 'Pyotr: Estoy buscando unos materiales.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904596
    m_Localized: 'Pyotr: A tii'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904595
    m_Localized: "Extra\xF1o: \xA1\xBFQUE VIENES A BUSCAR?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904594
    m_Localized: 'Pyotr: Vete a la mierda'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904593
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904592
    m_Localized: "Extra\xF1o: Por el culo te la hinco, je je je"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904591
    m_Localized: "Pyotr: \xA1QUE QU\xCDEN ERA!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904590
    m_Localized: "Extra\xF1o: \xA1\xBFCU\xC1L PREGUNTA?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904589
    m_Localized: "Pyotr: \xA1T\xDA ME PREGUNTASTE!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904588
    m_Localized: "Extra\xF1o: \xBFY para qu\xE9 quiero saber eso?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904587
    m_Localized: "Pyotr: \xBFPero quieres saber quien soy?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904586
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904585
    m_Localized: "Extra\xF1o: No se\xF1or, tu pelo no lo he tocado"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904584
    m_Localized: "Pyotr: \xBFMe est\xE1s tomando el pelo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904583
    m_Localized: "Extra\xF1o: \xBFEl qu\xE9?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904582
    m_Localized: 'Pyotr: Me lo acabas de preguntar.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904581
    m_Localized: "Extra\xF1o: Na uh"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904580
    m_Localized: 'Pyotr: Me has preguntado quien era.'
    m_Metadata:
      m_Items: []
  - m_Id: 3630011127775254
    m_Localized: "Extra\xF1o: \xA1\xBFHACE BUEN DIA VERDAD?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3630011127775255
    m_Localized: Pyotr salta, tocandose el pecho.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904577
    m_Localized: Se te ha olvidado algo importante...
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904576
    m_Localized: "\xBFC\xF3mo estas interactuando con \xE9l?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904575
    m_Localized: "El Extra\xF1o tiene los ojos cerrados, aunque parece confudido."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904574
    m_Localized: "Ya intentar\xE9 m\xE1s tarde... (Salir)"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904573
    m_Localized: Bueno, puedo continuar explorando y volver luego.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904572
    m_Localized: "Quizas deber\xEDas haber hablado con \xE9l antes de Lilia..."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904571
    m_Localized: "El Extra\xF1o tiene los ojos cerrados, claramente ignorando a Pyotr."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904570
    m_Localized: "Pyotr: \xBFPor qu\xE9 me preguntas eso?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904569
    m_Localized: 'Pyotr: (en tono musical) Soy yo'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904568
    m_Localized: "Extra\xF1o: \xA1\xBFQUI\xC9N ES?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904567
    m_Localized: "Pyotr: \xBFPerdona?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904566
    m_Localized: "Extra\xF1o: \xA1\xBFQU\xC9 HACES?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904565
    m_Localized: "Pyotr: Si... claro... Como si no me pesaran mis 75 a\xF1os."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904564
    m_Localized: "Extra\xF1o: La edad es mental jovencito."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904563
    m_Localized: "El Extra\xF1o se da golpes en la cabeza con el dedo indice."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904579
    m_Localized: "Extra\xF1o: \xBFQu\xE9 pregunta?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904578
    m_Localized: "O, \xBFquizas estas intentando arreglar tus errores?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904562
    m_Localized: 'Pyotr: No ves que soy una persona mayor.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904561
    m_Localized: 'Pyotr: Que susto joder.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904560
    m_Localized: Pyotr salta, tocandose el pecho.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904559
    m_Localized: "Extra\xF1o: \xA1\xBFHACE BUEN DIA VERDAD?!"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904558
    m_Localized: "Lilia: \xBFQu\xE9?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904557
    m_Localized: No, eso es todo por ahora. (Salir)
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904556
    m_Localized: "\xBFQuiz\xE1s hay m\xE1s cosas que ver?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904555
    m_Localized: "Lilia: \xA1Oh! No esperaba que fuese a por lo que buscaba, gracias
      Pyotr."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904554
    m_Localized: "Pyotr deja la nota y sale del taller. Tendr\xE1 que buscar los
      materiales con cuidado."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904553
    m_Localized: 'Pyotr: Jeje... que maja, voy a ver si puedo ayudarla.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904552
    m_Localized: En la nota, Lilia menciona que quiere fabricar un artefacto para
      sus piernas.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904551
    m_Localized: 'Pyotr: Veamos a ver que es lo que va a buscar...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904550
    m_Localized: Pyotr se acerca a la nota y la lee.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904549
    m_Localized: Lilia sale por la puerta pero deja una nota en la mesa.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904548
    m_Localized: 'Pyotr: Vale.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904547
    m_Localized: "Lilia: No hace falta, espera aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904546
    m_Localized: "Pyotr: \xBFQuieres que te acompa\xF1e?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904545
    m_Localized: "Lilia: Tengo que hacer unos recados, no tardar\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904544
    m_Localized: "Pyotr: \xBFA donde vas?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904543
    m_Localized: "Lilia: \xBFTe importa esperarme aqu\xED un momento?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904542
    m_Localized: 'Pyotr: No pasa nada.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904541
    m_Localized: "Lilia: Tranquilo, yo tambi\xE9n iba a lo mio."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904540
    m_Localized: 'Pyotr: Lo siento por lo de antes... no te he visto.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904539
    m_Localized: Pyotr pone la mano en la nuca.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904538
    m_Localized: 'Lilia: Gracias.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904537
    m_Localized: Lilia se sonroja.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904536
    m_Localized: "Pyotr: Incre\xEDble ni\xF1a."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904535
    m_Localized: 'Lilia: Si, lo he ido mejorando poco a poco.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904534
    m_Localized: Lilia le mira sobre el hombro.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904533
    m_Localized: "Pyotr: \xBFY esto es tuyo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904532
    m_Localized: "Lilia: 14 a\xF1os."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904531
    m_Localized: "Pyotr: \xBFY t\xFA?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904530
    m_Localized: Lilia se da la vuelta, dandole la espalda mientras anota cosas en
      un papel.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904529
    m_Localized: "Lilia: No simplemente ten\xEDa curiosidad."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904528
    m_Localized: "Pyotr: 75 a\xF1os, \xBFalguna raz\xF3n?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904527
    m_Localized: "Lilia: \xBFCuantos a\xF1os tienes?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904526
    m_Localized: 'Lilia: Tengo una duda.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904525
    m_Localized: 'Pyotr: Lo has clavado.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904524
    m_Localized: Pyotr le da una media sonrisa.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904523
    m_Localized: "Lilia: \xBFY todo esto para encontrar una cura para tu mujer?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904522
    m_Localized: 'Pyotr: Vas bien.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904521
    m_Localized: 'Lilia: Te has colado por unas escaleras que supuestamente tiene
      todas las plantas y que nadie conoce.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904520
    m_Localized: "Pyotr: As\xED es."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904519
    m_Localized: Pyotr afirma con la cabeza.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904518
    m_Localized: 'Lilia: No eres de esta planta.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904517
    m_Localized: 'Pyotr: Haz un resumen.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904516
    m_Localized: Lilia se toca la barbilla mientras lo mira.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904515
    m_Localized: 'Lilia: Entoncees... A ver si me ha quedado claro...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904514
    m_Localized: 'Pyotr: No sabes la cantidad de escaleras que hay.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904513
    m_Localized: Pyotr pone las manos en las rodillas, intentando recuperar el aliento.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904512
    m_Localized: 'Pyotr: Joder... que cansancio...'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389634
    m_Localized: '???: Y las almas corrompidas'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389633
    m_Localized: '???: Para blandir MI ESPADA!'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389632
    m_Localized: '???: No entiendo como hay gente que no entiende la puta vibra'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
