%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Traducion_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: a6dfaab2f9b3a344faa9d8eef5433298, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 35434348544
    m_Localized: Start
    m_Metadata:
      m_Items: []
  - m_Id: 103411433472
    m_Localized: Options
    m_Metadata:
      m_Items: []
  - m_Id: 145530634240
    m_Localized: English
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721923
    m_Localized: '???: This matcha is so good'
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721920
    m_Localized: 'Pyotr: Hello kid'
    m_Metadata:
      m_Items: []
  - m_Id: 2813296721921
    m_Localized: 'Pyotr: Excuse me, can I ask you a question?'
    m_Metadata:
      m_Items: []
  - m_Id: 3292595779092480
    m_Localized: Quit
    m_Metadata:
      m_Items: []
  - m_Id: 3292750330806272
    m_Localized: Save
    m_Metadata:
      m_Items: []
  - m_Id: 3293267467517952
    m_Localized: Spanish
    m_Metadata:
      m_Items: []
  - m_Id: 3609736646574080
    m_Localized: Options
    m_Metadata:
      m_Items: []
  - m_Id: 3609796801282048
    m_Localized: Back
    m_Metadata:
      m_Items: []
  - m_Id: 3613258045800448
    m_Localized: Load
    m_Metadata:
      m_Items: []
  - m_Id: 10173553655808
    m_Localized: '???: Who are you calling kid? I''m 32 years old!'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850112
    m_Localized: She seems mad.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850113
    m_Localized: Pyotr rubs the back of his neck
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850114
    m_Localized: 'Pyotr: Ah... please forgive me'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850115
    m_Localized: '???: I know my height doesn''t help, but you shouldn''t be so prejudiced.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850116
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850117
    m_Localized: '???: It''s like if I said, "hey mummy!"'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850118
    m_Localized: 'Pyotr: I understand. I truly am sorry.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850119
    m_Localized: 'Pyotr: I think you''ve gone a bit far.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850120
    m_Localized: Better not say anything
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850121
    m_Localized: '???: Yes, of course, tell me.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850122
    m_Localized: 'Pyotr: I''m looking for some things for a friend, could you help
      me?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850123
    m_Localized: '???: What are you looking for exactly?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850124
    m_Localized: 'Pyotr: Several things, honestly.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850125
    m_Localized: '???: Well, tell me one, let''s see if I can help you.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850126
    m_Localized: 'Pyotr: Do you know where I could find some wooden planks?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850127
    m_Localized: '???: Hmm... I think by the tavern, there''s some strewn about the
      floor.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850128
    m_Localized: 'Pyotr: Perfect. And where can I find the tavern?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850129
    m_Localized: '???: At the end of the street you can find it.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850130
    m_Localized: 'Pyotr: Thank you very much, miss.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850131
    m_Localized: '???: It''s just, I feel quite bad when I''m treated as if I were
      a kid. I apologize if I was a bit intense.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850132
    m_Localized: 'Pyotr: I understand, the same happened to me at your age. I''ve
      always been short, so I understand your anger.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850133
    m_Localized: '???: To be honest, you really are quite short. I hadn''t noticed.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850134
    m_Localized: 'Pyotr: Now that we have solved this little scuffle, could you help
      me find something?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850135
    m_Localized: '???: Of course, what are you looking for?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850136
    m_Localized: 'Pyotr: I''m looking for some wooden planks.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850137
    m_Localized: She scratches her chin while she thinks.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850138
    m_Localized: '???: If you follow this street, you might some, near the tavern.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850139
    m_Localized: 'Pyotr: Perfect, thank you so much and apologies for earlier'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850140
    m_Localized: '???: It''s alright, have a nice day, sir'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850141
    m_Localized: She raises her voice, almost yelling.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850142
    m_Localized: '???: I am not going too far! I''m tired of being confused for a
      little kid!'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850143
    m_Localized: 'Pyotr: I already told you I''m sorry, there''s no need to continue
      with this.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850144
    m_Localized: '???: Sure it does! Some old man like you isn''t going to just come
      by and call me a kid'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850145
    m_Localized: Now, Pyotr is also starting to get mad.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850146
    m_Localized: 'Pyotr: You really are starting to go too far'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850147
    m_Localized: '???: You know what? Leave. I don''t want to see you around here.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850148
    m_Localized: 'Pyotr: But I need your help to find something'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850149
    m_Localized: '???: LEAVE! Or I will call the guards!'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850150
    m_Localized: 'Pyotr: Okay, okay, I''m going'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850151
    m_Localized: She laughs, making fun of him.
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850152
    m_Localized: '???: What happened? Cat got your tongue?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850153
    m_Localized: 'Pyotr: Look, ma''am, I''m an old man, I''m tired and I''m not in
      the mood to get in a fight with someone.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850154
    m_Localized: '???: Don''t treat me as ma''am, I''m still young.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850155
    m_Localized: 'Pyotr: I''m sorry if I offended you. I just want to help my friend.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850156
    m_Localized: '???: And who is your friend?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850157
    m_Localized: 'Pyotr: Her name is Lilia, I''m working at her shop so I''m helping
      her gather some materials.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850158
    m_Localized: '???: I know Lilia, heard she''s a genius. Though, from what I''ve
      heard, I find it quite hard to believe she''d want anyone''s help'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850159
    m_Localized: 'Pyotr: I''m doing it without her knowing'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850160
    m_Localized: '???: That''s quite nice of you. What are you looking for?'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850161
    m_Localized: 'Pyotr: I''m looking for some wooden planks'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850162
    m_Localized: '???: If you follow this street, you might some, near the tavern.'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850163
    m_Localized: 'Pyotr: Thank you for your help'
    m_Metadata:
      m_Items: []
  - m_Id: 10173557850164
    m_Localized: '???: No worries'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931776
    m_Localized: 'Pyotr: Excuse me, but can you carry weapons in this city?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931777
    m_Localized: 'Pyotr: Nice sword, friend'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931778
    m_Localized: '???: It''s a lovely day'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931779
    m_Localized: '???: Excuse me?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931780
    m_Localized: 'Pyotr: I was simply asking if that weapon is legal'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931781
    m_Localized: '???: What is it to you?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931782
    m_Localized: '???: Plus, who even are you?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931783
    m_Localized: 'Pyotr: And why do you care who I am?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931784
    m_Localized: 'Pyotr: I''m Pyotr'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931785
    m_Localized: '???: Thanks, it''s a family heirloom'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931786
    m_Localized: 'Pyotr: Well it''s quite lovely, could I see it?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931787
    m_Localized: '???: Sorry, but I don''t let anyone touch it'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931788
    m_Localized: 'Pyotr: No worries, I understand'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931789
    m_Localized: '???: Do you need something?'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931790
    m_Localized: 'Pyotr: Well, now that you mention it, yes'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931791
    m_Localized: 'Pyotr: I''m looking for some gears'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931792
    m_Localized: '???: Around here there''s a store where you could buy some'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931793
    m_Localized: 'Pyotr: The thing is that between not having any money and me not
      being from around here, I wouldn''t be able to buy them'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931794
    m_Localized: '???: Right...'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931795
    m_Localized: '???: Look, Pyotr, if you go right and to the end of the street,
      you''ll find a waste site. Might find some there'
    m_Metadata:
      m_Items: []
  - m_Id: 12624985931796
    m_Localized: 'Pyotr: Many thanks, friend. Take care'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268672
    m_Localized: '???: If you want us to be fine, answer me'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268673
    m_Localized: Slowly, they start to unsheathe their sword
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268674
    m_Localized: 'Pyotr: I''m simply saying you don''t seem to be a guard or anything
      like that'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268675
    m_Localized: '???: Why would I need to appear as a guard?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268676
    m_Localized: With each word, they unsheathe the sword more.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268677
    m_Localized: '???: Are you hiding something?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268678
    m_Localized: More.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268679
    m_Localized: Pyotr briefle glances at the sword, clearing his throat.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268680
    m_Localized: 'Pyotr: No, no, I''m not hiding anything'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268681
    m_Localized: 'Pyotr: I''m just saying it''s odd that you''re not a guard and
      have a sword'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268682
    m_Localized: It seems that calms them down, sheathing their sword.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268683
    m_Localized: '???: Well, looking it that way, you have a point'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268684
    m_Localized: They unsheathe their sword
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268685
    m_Localized: '???: Even so, you haven''t answered me'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268686
    m_Localized: '???: Answer me or I''m cutting you in half like a bamboo stick'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268687
    m_Localized: '???: I better leave, you''re not all there in the head'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268688
    m_Localized: '???: You''re not from around here, right?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268689
    m_Localized: 'Pyotr: To be honest, I''m not. I''m from the lower floor'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268690
    m_Localized: '???: And what are you doing around here?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268691
    m_Localized: 'Pyotr: You''re asking a lot of questions, no?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268692
    m_Localized: 'Pyotr: I''m helping out a friend to look for some materials and
      need help'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268693
    m_Localized: They unsheathe half of their sword.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268694
    m_Localized: '???: If you want us to be fine, answer me'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268695
    m_Localized: 'Pyotr: I don''t want any trouble, friend, just-'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268696
    m_Localized: Before he can finish, they interrumpt.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268697
    m_Localized: '???: Better get out of my sight'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268698
    m_Localized: 'Pyotr: Please, I need help'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268699
    m_Localized: They fully unsheathe their sword.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268700
    m_Localized: '???: Leave'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268701
    m_Localized: 'Pyotr: Okay, calm down'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268702
    m_Localized: They offer their hand to Pyotr.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268703
    m_Localized: '???: Alright, I''ll trust you'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268704
    m_Localized: Pyotr smiles and takes their hand.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268705
    m_Localized: 'Pyotr: Thank you, friend'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268706
    m_Localized: '???: Say Pyotr, what do you need?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268707
    m_Localized: 'Pyotr: I''m looking for some gears'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268708
    m_Localized: '???: Around here there''s a store where you could buy some'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268709
    m_Localized: 'Pyotr: The thing is that between not having any money and me not
      being from around here, I wouldn''t be able to buy them'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268710
    m_Localized: '???: Right... look, Pyotr, if you go right and to the end of the
      street, you''ll find a waste site. Might find some there'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268711
    m_Localized: 'Pyotr: Many thanks, friend. Take care'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268712
    m_Localized: 'Pyotr: Excuse me, are you a priest or a vampire?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268713
    m_Localized: '???: Excuse me, are you a priest?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268714
    m_Localized: '???: May the goddess forgive us'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840586268715
    m_Localized: His brows furrow
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462976
    m_Localized: '???: Nobody show you some manners?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462977
    m_Localized: 'Pyotr: It was just a question, don''t get offended man'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462978
    m_Localized: '???: How do you expect me to not get offended?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462979
    m_Localized: '???: You just asked me if I''m a vampire'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462980
    m_Localized: Pyotr shrugs
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462981
    m_Localized: 'Pyotr: Actually, I asked if you were a priest or a vampire'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462982
    m_Localized: 'Pyotr: Buttttttt.... you do know, right?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462983
    m_Localized: '???: Know what?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462984
    m_Localized: 'Pyotr: If you''re a vampire or not'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462985
    m_Localized: He scratches his ears.
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462986
    m_Localized: '???: The things I have to put up with...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462987
    m_Localized: '???: You''re just an old coot'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462988
    m_Localized: 'Pyotr: Hey, there''s no need to disrespect the elderly'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462989
    m_Localized: 'Pyotr: It''d be quite rude if a priest called me an old coot'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462990
    m_Localized: '???: You know what? Goodbye, I don''t have time for stupidity'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462991
    m_Localized: '???: To be honest, no, but I''m a devoted follower'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462992
    m_Localized: Pyotr lowers his head
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462993
    m_Localized: 'Pyotr: Ah... alright...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462994
    m_Localized: '???: Do you need something?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462995
    m_Localized: 'Pyotr: To be honest...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462996
    m_Localized: 'Pyotr: (With tears in his eyes) Lately, I''ve started to lose faith
      in the gods'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590462997
    m_Localized: 'Pyotr: I need to know where I can find springs. Do you know where
      to find them?'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389632
    m_Localized: '???: I don''t understand how people don''t understand the fucking
      vibe'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389633
    m_Localized: '???: To brandish MY SWORD'
    m_Metadata:
      m_Items: []
  - m_Id: 3658267000389634
    m_Localized: '???: And the condemned souls'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463001
    m_Localized: 'Pyotr: She''s a good person and has never hurt anyone. Why must
      this happen to her?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463002
    m_Localized: '???: I understand your frustration, friend, but you shouldn''t
      lose faith because of this'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463003
    m_Localized: '???: The gods are merciful, surely they have a plan for her'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463004
    m_Localized: 'Pyotr: I hope so...'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463005
    m_Localized: 'Pyotr: I still have my doubts... but thank you for talking to me'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463006
    m_Localized: '???: Of course'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463007
    m_Localized: '???: Do you need anything else?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463008
    m_Localized: 'Pyotr: Well, I am looking for some springs. Do you know where I
      could find some?'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463009
    m_Localized: '???: Yes, going down the street, near the wall. I believe there''s
      some remains where you could find some'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463010
    m_Localized: 'Pyotr: Alright, thank you'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463011
    m_Localized: '???: It''s no problem, and remember, have faith'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463012
    m_Localized: '???: Yes, going down the street, near the wall. I believe there''s
      some remains where you could find some'
    m_Metadata:
      m_Items: []
  - m_Id: 3291840590463013
    m_Localized: 'Pyotr: Alright, thank you'
    m_Metadata:
      m_Items: []
  - m_Id: 3630011127775254
    m_Localized: 'Stranger: IT''S A LOVELY DAY, RIGHT?'
    m_Metadata:
      m_Items: []
  - m_Id: 3630011127775255
    m_Localized: Pyotr jumps, clutching his chest.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904512
    m_Localized: 'Pyotr: Fuck... I''m exhausted'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904513
    m_Localized: Pyotr puts his hands on his knees, trying to catch his breath.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904514
    m_Localized: 'Pyotr: You have no idea how many stairs there are'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904515
    m_Localized: 'Lilia: Then... let''s see if I''ve got this right'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904516
    m_Localized: Lilia taps her chin while looking at him.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904517
    m_Localized: 'Pyotr: Summarize it'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904518
    m_Localized: 'Lilia: You''re not of this floor'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904519
    m_Localized: Pyotr nods in affirmation.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904520
    m_Localized: 'Pyotr: Right'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904521
    m_Localized: 'Lilia: You snuck in through some stairs that apparently has all
      the floors attached and nobody knows of it'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904522
    m_Localized: 'Pyotr: You''re right'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904523
    m_Localized: 'Lilia: And all of this to find a cure for your wife?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904524
    m_Localized: Pyotr gives her a half smile.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904525
    m_Localized: 'Pyotr: Hit the nail on the head'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904526
    m_Localized: 'Lilia: I have a question'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904527
    m_Localized: 'Lilia: How old are you?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904528
    m_Localized: 'Pyotr: 75 years old, why?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904529
    m_Localized: 'Lilia: Nothing, just curious'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904530
    m_Localized: Lilia turns, facing away from him as she writes things down on a
      paper.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904531
    m_Localized: 'Pyotr: And you?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904532
    m_Localized: 'Lilia: 14 years old'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904533
    m_Localized: 'Pyotr: And this place is yours?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904534
    m_Localized: Lilia glances at him over her shoulder.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904535
    m_Localized: 'Lilia: Yes, I''ve been improving it slowly'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904536
    m_Localized: 'Pyotr: Incredible, kid'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904537
    m_Localized: Lilia blushes.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904538
    m_Localized: 'Lilia: Thanks'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904539
    m_Localized: Pyotr rubs the back of his neck.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904540
    m_Localized: 'Pyotr: Sorry about earlier... I didn''t see you'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904541
    m_Localized: 'Lilia: No worries, I was also in my own head'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904542
    m_Localized: 'Pyotr: Do you mind waiting for me here for a moment?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904543
    m_Localized: 'Lilia: Do you mind waiting for me here for a moment?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904544
    m_Localized: 'Pyotr: Where are you going?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904545
    m_Localized: 'Lilia: I have to run some errands, I won''t be long'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904546
    m_Localized: 'Pyotr: Do you want me to tag along?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904547
    m_Localized: 'Lilia: No, no need. Wait here.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904548
    m_Localized: 'Pyotr: Alright.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904549
    m_Localized: Lilia walks out the door but leaves the note on the desk.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904550
    m_Localized: Pyotr walks over and reads the note.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904551
    m_Localized: 'Pyotr: Let''s see what you were going to look for...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904552
    m_Localized: On the note, Lilia mentions wanting to make an artifact for his
      legs.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904553
    m_Localized: 'Pyotr: Haha... how nice, let''s see if I can help her'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904554
    m_Localized: Pyotr leaves the note and walks out of the workshop. He'll have
      to look for the materials carefully.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904555
    m_Localized: 'Lilia: Oh! I wasn''t expection you''d go look for them. Thank you,
      Pyotr.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904556
    m_Localized: Maybe there's more things to explore?
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904557
    m_Localized: No, that's all for now. (Quit)
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904558
    m_Localized: 'Lilia: What?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904559
    m_Localized: 'Stranger: IT''S A LOVELY DAY, RIGHT?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904560
    m_Localized: Pyotr jumps, clutching his chest.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904561
    m_Localized: 'Pyotr: What a scare, holy shit'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904562
    m_Localized: 'Pyotr: Can''t you see I''m an old man'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904563
    m_Localized: The Stranger hits his head with his index finger.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904564
    m_Localized: 'Stranger: Age is mental, young man'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904565
    m_Localized: 'Pyotr: Right... of course... as if my 75 years of age didn''t exist'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904566
    m_Localized: 'Stranger: WHAT ARE YOU DOING?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904567
    m_Localized: 'Pyotr: Excuse me?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904568
    m_Localized: 'Stranger: WHO IS IT?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904569
    m_Localized: 'Pyotr: (lilting) It''s me~'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904570
    m_Localized: 'Pyotr: Why do you ask me that?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904571
    m_Localized: The Stranger has his eyes closed, clearly ignoring Pyotr.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904572
    m_Localized: Maybe you should have talked to him before Lilia...
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904573
    m_Localized: Well, I can continue exploring and return later.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904574
    m_Localized: I'll try again later... (Quit)
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904575
    m_Localized: The Stranger has his eyes closed, though he seems confused.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904576
    m_Localized: How are you interacting with him?
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904577
    m_Localized: You must have forgotten something important...
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904578
    m_Localized: Or, maybe you're trying to fix your mistakes?
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904579
    m_Localized: 'Stranger: What question?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904580
    m_Localized: 'Pyotr: You asked me who I am.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904581
    m_Localized: 'Stranger: Nuh uh.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904582
    m_Localized: 'Pyotr: You just asked.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904583
    m_Localized: 'Stranger: Asked what?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904584
    m_Localized: 'Pyotr: Are you pulling my leg?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904585
    m_Localized: 'Stranger: No sir, I haven''t touched your leg'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904586
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904587
    m_Localized: 'Pyotr: But you want to ask who I am?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904588
    m_Localized: 'Stranger: And why would I want to know that?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904589
    m_Localized: 'Pyotr: YOU ASKED ME!'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904590
    m_Localized: 'Stranger: WHAT QUESTION!?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904591
    m_Localized: 'Pyotr: WHO I AM!'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904592
    m_Localized: "Stranger: Up your butt and there it\u2019s stuck, heh heh"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904593
    m_Localized: 'Pyotr: ...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904594
    m_Localized: 'Pyotr: Fuck off'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904595
    m_Localized: 'Stranger: WHO ARE YOU LOOKING FOR?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904596
    m_Localized: 'Pyotr: Youuuu'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904597
    m_Localized: 'Pyotr: I''m looking for materials.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904598
    m_Localized: 'Stranger: Sorry, but I don''t give that type of information'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904599
    m_Localized: 'Pyotr: What? Why not?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904600
    m_Localized: 'Stranger: I must go now'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904601
    m_Localized: The Stranger closes his eyes, not moving from where he stands.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904602
    m_Localized: Pyotr looks at him, disconcerted.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904603
    m_Localized: 'Pyotr: You only closed your eyes'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904604
    m_Localized: 'Stranger: I don''t exist, I am not a character'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904605
    m_Localized: 'Pyotr: What a character...'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904606
    m_Localized: 'Stranger: IT''S ALREADY LATE!'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904607
    m_Localized: 'Pyotr: Why?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904608
    m_Localized: 'Pyotr: But it''s not even 18:00'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904609
    m_Localized: 'Stranger: What did I say to my brother-in-law?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904610
    m_Localized: "Pyotr: Who\u2019s your brother-in-law?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904611
    m_Localized: "Pyotr: Who\u2019s your brother-in-law?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904612
    m_Localized: 'Stranger: What do you think of the river?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904613
    m_Localized: "Pyotr: The river\u2026 total crap."
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904614
    m_Localized: 'Pyotr: Is there a river up here?'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904615
    m_Localized: "Stranger: To be out here looking at this artichoke field\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904616
    m_Localized: 'Pyotr: It really gets to me.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904617
    m_Localized: "Pyotr: But aren\u2019t the crops in my floor?"
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904618
    m_Localized: 'Stranger: You have passed the test, here, take this as a reward.'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904619
    m_Localized: The Stranger gives Pyotr a purple rock with a strange tone
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904620
    m_Localized: 'Pyotr: Ah... thank you very much, boss'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904621
    m_Localized: It'd be best to return to Lilia, it's getting late.
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904622
    m_Localized: 'Stranger: We will meet again, goodbye'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904623
    m_Localized: 'Pyotr: What a strange man'
    m_Metadata:
      m_Items: []
  - m_Id: 3650776371904624
    m_Localized: Better to return to Lilia and give her the materials.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
